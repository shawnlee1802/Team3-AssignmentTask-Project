<!DOCTYPE html>
<html>
<head>
    <title>Register - Assignment Tracker</title>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        body {
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f4f7fc;
        }
        .register-wrapper {
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            background: linear-gradient(to right, #ffffff, #f4f7fc);
        }
        .register-card {
            background: white;
            padding: 48px 40px;
            border-radius: 16px;
            box-shadow: 0 12px 30px rgba(0, 0, 0, 0.08);
            width: 100%;
            max-width: 400px;
            border: 1px solid #e9edf2;
        }
        .register-card h1 {
            font-size: 28px;
            font-weight: 700;
            margin-bottom: 8px;
            color: #1c2b3a;
        }
        .register-card .subtitle {
            color: #6b7b8a;
            font-size: 15px;
            margin-bottom: 28px;
        }
        .register-card label {
            font-weight: 600;
            font-size: 14px;
            color: #2d3e4f;
            display: block;
            margin-bottom: 6px;
        }
        .register-card input {
            width: 100%;
            padding: 12px 16px;
            border: 1.5px solid #dce3eb;
            border-radius: 10px;
            font-size: 15px;
            background: #fafbfc;
            transition: 0.2s;
            margin-bottom: 18px;
            box-sizing: border-box;
        }
        .register-card input:focus {
            outline: none;
            border-color: #3b82f6;
            background: white;
            box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.15);
        }
        .register-btn {
            width: 100%;
            background: #2c7be5;
            color: white;
            border: none;
            padding: 14px;
            font-weight: 700;
            font-size: 16px;
            border-radius: 10px;
            cursor: pointer;
            transition: 0.2s;
            margin-top: 4px;
        }
        .register-btn:hover {
            background: #1a5fc7;
        }
        .register-card .login-link {
            text-align: center;
            margin-top: 22px;
            font-size: 15px;
            color: #4b5f71;
        }
        .register-card .login-link a {
            color: #2c7be5;
            text-decoration: none;
            font-weight: 600;
        }
        .register-card .login-link a:hover {
            text-decoration: underline;
        }
        .alert {
            background: #fee9e7;
            border-left: 4px solid #e34843;
            color: #b33630;
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-weight: 500;
        }
    </style>
</head>
<body>
    <div class="register-wrapper">
        <div class="register-card">
            <h1>Create an account</h1>
            <p class="subtitle">Start tracking your assignments now</p>

            <% if (locals.error) { %>
                <div class="alert"><%= error %></div>
            <% } %>

            <form action="/register" method="POST">
                <label for="name">Full name</label>
                <input type="text" id="name" name="name" placeholder="John Doe" required>

                <label for="email">Email address</label>
                <input type="email" id="email" name="email" placeholder="you@example.com" required>

                <label for="password">Password</label>
                <input type="password" id="password" name="password" placeholder="Create a password" required>

                <button type="submit" class="register-btn">Create account</button>
            </form>

            <div class="login-link">
                Already have an account? <a href="/login">Log in</a>
            </div>
        </div>
    </div>
</body>
</html>