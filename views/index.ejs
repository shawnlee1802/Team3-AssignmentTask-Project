<%- include("partials/header") %>

<div class="d-flex flex-column flex-md-row justify-content-between align-items-start align-items-md-center mb-4">
    <div>
        <h1 class="h3 mb-1">Dashboard</h1>
        <p class="text-muted mb-0">Simple overview of your assignments and deadlines.</p>
    </div>
    <div class="d-flex gap-2 mt-3 mt-md-0">
        <a href="/assignments/add" class="btn btn-primary">Add Assignment</a>
        <a href="/assignments" class="btn btn-outline-primary">View Assignments</a>
    </div>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Total Assignments</p>
                <h2 class="mb-0"><%= dashboard.total %></h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Pending</p>
                <h2 class="mb-0"><%= dashboard.pending %></h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Due This Week</p>
                <h2 class="mb-0"><%= dashboard.dueThisWeek %></h2>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Completed</p>
                <h2 class="mb-0"><%= dashboard.completed %></h2>
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5">Progress</h2>
                <div class="progress my-3" role="progressbar" aria-label="Assignment completion" aria-valuenow="<%= dashboard.progress %>" aria-valuemin="0" aria-valuemax="100">
                    <div class="progress-bar" <%- `style="width: ${dashboard.progress}%;"` %>>
                        <%= dashboard.progress %>%
                    </div>
                </div>
                <p class="mb-1">Completed: <%= dashboard.completed %> / <%= dashboard.total %></p>
                <p class="mb-1">High Priority: <%= dashboard.highPriority %></p>
                <p class="mb-0">Overdue: <%= dashboard.overdue %></p>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card shadow-sm h-100">
            <div class="card-body">
                <h2 class="h5">Upcoming Deadlines</h2>

                <% if (upcomingDeadlines.length) { %>
                    <div class="table-responsive">
                        <table class="table align-middle mb-0">
                            <thead>
                                <tr>
                                    <th>Assignment</th>
                                    <th>Module</th>
                                    <th>Due Date</th>
                                </tr>
                            </thead>
                            <tbody>
                                <% upcomingDeadlines.forEach((assignment) => { %>
                                    <tr>
                                        <td>
                                            <%= assignment.assignment_title %>
                                            <% if (assignment.reminderCountdown) { %>
                                                <small class="d-block <%= assignment.reminderCountdown.className %>">
                                                    <%= assignment.reminderCountdown.text %>
                                                </small>
                                            <% } %>
                                        </td>
                                        <td><%= assignment.module_name %></td>
                                        <td><%= assignment.due_date %></td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                <% } else { %>
                    <p class="text-muted mb-0">No upcoming deadlines yet.</p>
                <% } %>
            </div>
        </div>
    </div>
</div>

<%- include("partials/footer") %>
